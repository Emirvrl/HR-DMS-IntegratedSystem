@model List<DMS.Mvc.Models.SystemLogViewModel>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>System Logs</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="p-4 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between mb-4">
            <h2>System Audit Logs</h2>
            <a href="/Home/Index" class="btn btn-secondary">Back</a>
        </div>

        <div class="card shadow">
            <div class="card-body">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Date</th>
                            <th>User</th>
                            <th>Document</th>
                            <th>Action / Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td>@log.ChangeDate.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td><span class="badge bg-info text-dark">@log.ChangedByName</span></td>
                                <td>@log.DocumentTitle</td>
                                <td>@log.Status</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>