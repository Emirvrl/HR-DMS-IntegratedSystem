@model HRDms.Data.Models.DocumentDetailViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Document Details - @Model.Title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body class="bg-light p-4">

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <a href="/Document/Index" class="btn btn-outline-secondary">&larr; Back to List</a>

            <div>
                @if ((Model.CurrentStatus == "Draft" || Model.CurrentStatus == "Pending")
                                && Context.Session.GetString("IsManager") == "true")
                {
                    <form asp-action="ChangeStatus" method="post" style="display:inline;">
                        <input type="hidden" name="documentId" value="@Model.DocumentID" />
                        <input type="hidden" name="newStatus" value="Approved" />
                        <button type="submit" class="btn btn-success"><i class="bi bi-check-circle"></i> Approve</button>
                    </form>

                    <form asp-action="ChangeStatus" method="post" style="display:inline;">
                        <input type="hidden" name="documentId" value="@Model.DocumentID" />
                        <input type="hidden" name="newStatus" value="Rejected" />
                        <button type="submit" class="btn btn-danger ms-1"><i class="bi bi-x-circle"></i> Reject</button>
                    </form>
                }
                else if (Model.CurrentStatus == "Rejected" && Context.Session.GetString("IsManager") == "true")
                {
                    <form asp-action="ChangeStatus" method="post" style="display:inline;">
                        <input type="hidden" name="documentId" value="@Model.DocumentID" />
                        <input type="hidden" name="newStatus" value="Pending" />
                        <button type="submit" class="btn btn-warning text-dark"><i class="bi bi-arrow-counterclockwise"></i> Re-evaluate</button>
                    </form>
                }
                else if (Model.CurrentStatus == "Pending" && Context.Session.GetString("IsManager") != "true")
                {
                    <span class="text-muted fst-italic"><i class="bi bi-hourglass-split"></i> Waiting for manager approval...</span>
                }
            </div>
        </div>

        <div class="row">
            <div class="col-md-8">
                <div class="card shadow mb-4">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">@Model.Title</h4>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Category:</strong> <br>
                                <span class="badge bg-info text-dark">@Model.CategoryName</span>
                            </div>
                            <div class="col-md-6 text-end">
                                <strong>Current Status:</strong> <br>
                                <span class="badge bg-secondary fs-6">@Model.CurrentStatus</span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <strong>Description:</strong>
                            <p class="text-muted border p-3 rounded bg-light mt-1">
                                @(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)
                            </p>
                        </div>

                        <div class="row text-muted">
                            <div class="col-md-6">
                                <small>Uploaded By:</small> <strong>@Model.OwnerName</strong>
                            </div>
                            <div class="col-md-6">
                                <small>Date:</small> <strong>@Model.CreatedDate.ToString("yyyy-MM-dd HH:mm")</strong>
                            </div>
                        </div>

                        <hr />

                        @if (!string.IsNullOrEmpty(Model.FilePath))
                        {
                            <a href="/Document/DownloadFile/@Model.DocumentID" class="btn btn-primary w-100">
                                <i class="bi bi-download"></i> Download File (@Model.FileName)
                            </a>
                        }
                        else
                        {
                            <div class="alert alert-warning">File not found.</div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0"><i class="bi bi-clock-history"></i> Audit History</h5>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-striped mb-0 text-center" style="font-size: 0.9rem;">
                            <thead>
                                <tr>
                                    <th>Status</th>
                                    <th>User</th>
                                    <th>Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.History != null && Model.History.Count > 0)
                                {
                                    foreach (var log in Model.History)
                                    {
                                        <tr>
                                            <td>@log.Status</td>
                                            <td>@log.ChangedByName</td>
                                            <td>@log.ChangeDate.ToString("MM-dd HH:mm")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="text-muted py-3">No history yet.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12">
                <div class="card shadow">
                    <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-layers-half"></i> Version History</h5>

                        <button type="button" class="btn btn-sm btn-light text-dark fw-bold" data-bs-toggle="modal" data-bs-target="#newVersionModal">
                            <i class="bi bi-plus-circle"></i> Upload New Version
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-bordered table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Version</th>
                                    <th>File Name</th>
                                    <th>Uploader</th>
                                    <th>Date</th>
                                    <th>Note</th>
                                    @if (Context.Session.GetString("IsManager") == "true")
                                    {
                                        <th style="width: 150px;">Admin</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ver in Model.Versions)
                                {
                                    var isLatest = (ver == Model.Versions.First());
                                    <tr class="@(isLatest ? "table-success" : "")">
                                        <td class="fw-bold">v.@ver.VersionNumber</td>
                                        <td>@ver.FileName</td>
                                        <td>@ver.UploadedByName</td>
                                        <td>@ver.UploadDate?.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@ver.ChangeNote</td>

                                        @if (Context.Session.GetString("IsManager") == "true")
                                        {
                                            <td class="text-center">
                                                @if (!isLatest)
                                                {
                                                    <form asp-action="RollbackVersion" method="post" onsubmit="return confirm('Are you sure you want to rollback to this version?');">
                                                        <input type="hidden" name="versionId" value="@ver.VersionID" />
                                                        <input type="hidden" name="documentId" value="@Model.DocumentID" />
                                                        <button type="submit" class="btn btn-sm btn-outline-dark">
                                                            <i class="bi bi-arrow-counterclockwise"></i> Rollback
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success">Current</span>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="newVersionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Upload New Version</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <form action="/Document/UploadNewVersion" method="post" enctype="multipart/form-data">
                    <div class="modal-body">
                        <input type="hidden" name="documentId" value="@Model.DocumentID" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Select New File</label>
                            <input type="file" name="file" class="form-control" accept=".pdf,.docx,.xlsx,.jpg,.png" required />
                            <small class="text-muted">Previous version is archived, not deleted.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Change Note</label>
                            <textarea name="changeNote" class="form-control" rows="2" placeholder="e.g. Typos fixed..." required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Upload and Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>