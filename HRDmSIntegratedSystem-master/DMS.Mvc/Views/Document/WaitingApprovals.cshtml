@model List<HRDms.Data.Models.DocumentListViewModel>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Pending Approvals</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body class="bg-light p-4">

    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-danger"><i class="bi bi-hourglass-split"></i> Pending Approvals</h2>
            <a href="/Home/Index" class="btn btn-outline-secondary">Back to Dashboard</a>
        </div>

        <div class="card shadow border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">Pending Tasks in Your Department</h5>
            </div>
            <div class="card-body">
                @if (Model != null && Model.Count > 0)
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-info-circle"></i> You have <strong>@Model.Count</strong> documents waiting for approval.
                    </div>

                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Document</th>
                                <th>Uploader</th>
                                <th>Category</th>
                                <th>Upload Date</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in Model)
                            {
                                <tr>
                                    <td class="fw-bold">@doc.Title</td>
                                    <td>@doc.OwnerName</td>
                                    <td><span class="badge bg-secondary">@doc.CategoryName</span></td>
                                    <td>@doc.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td class="text-center">
                                        <a href="/Document/Details/@doc.DocumentID" class="btn btn-primary btn-sm">
                                            <i class="bi bi-search"></i> Review & Decide
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-check-circle-fill fs-1 text-success mb-3"></i>
                        <h4>Great!</h4>
                        <p>You have no pending approvals.</p>
                    </div>
                }
            </div>
        </div>
    </div>

</body>
</html>