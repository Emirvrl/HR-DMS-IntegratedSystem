@model HRDms.Data.Models.Location
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Lokasyon Düzenle</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light p-4">
    <div class="container">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h3>Edit Location</h3>
            </div>
            <div class="card-body">
                <form method="post">
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.LocationId)

                    <div class="mb-3">
                        <label class="form-label">Lokasyon Adı *</label>
                        <input asp-for="LocationName" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Adres</label>
                        <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                    </div>

                    <button type="submit" class="btn btn-info">Güncelle</button>
                    <a href="@Url.Action("Locations")" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>