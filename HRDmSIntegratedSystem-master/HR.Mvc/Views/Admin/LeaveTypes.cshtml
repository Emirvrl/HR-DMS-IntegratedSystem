@model List<HRDms.Data.Models.LeaveType>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>Leave Types</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container">
        <div class="d-flex justify-content-between mb-3">
            <h2><i class="fas fa-calendar-alt"></i> Leave Types</h2>
            <div>
                <a href="@Url.Action("CreateLeaveType")" class="btn btn-warning">
                    <i class="fas fa-plus"></i> Create New
                </a>
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }

        <div class="card">
            <div class="card-body">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Leave Type</th>
                            <th>Annual Allowance (Days)</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var leaveType in Model)
                        {
                            <tr>
                                <td>@leaveType.LeaveTypeId</td>
                                <td>@leaveType.TypeName</td>
                                <td>@(leaveType.DaysAllowed?.ToString() ?? "Unlimited")</td>
                                <td>
                                    <a href="@Url.Action("EditLeaveType", new { id = leaveType.LeaveTypeId })" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" asp-action="DeleteLeaveType" asp-route-id="@leaveType.LeaveTypeId"
                                          onsubmit="return confirm('Are you sure you want to delete?')" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>