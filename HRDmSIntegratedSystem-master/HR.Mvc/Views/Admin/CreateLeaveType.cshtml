@model HRDms.Data.Models.LeaveType
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>New Leave Type</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light p-4">
    <div class="container">
        <div class="card">
            <div class="card-header bg-warning">
                <h3>Add New Leave Type</h3>
            </div>
            <div class="card-body">
                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Leave Type Name *</label>
                        <input asp-for="TypeName" class="form-control" placeholder="e.g. Annual Leave" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Annual Allowance (Days)</label>
                        <input asp-for="DaysAllowed" type="number" class="form-control" placeholder="Leave empty for unlimited" />
                        <small class="text-muted">Leave empty for unlimited allowance</small>
                    </div>

                    <button type="submit" class="btn btn-warning">Save</button>
                    <a href="@Url.Action("LeaveTypes")" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>