@model List<HRDms.Data.Models.Job>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Job Positions</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container">
        <div class="d-flex justify-content-between mb-3">
            <h2><i class="fas fa-briefcase"></i> Job Positions</h2>
            <div>
                <a href="@Url.Action("CreateJob")" class="btn btn-success">
                    <i class="fas fa-plus"></i> Create New
                </a>
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }

        <div class="card">
            <div class="card-body">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Position Title</th>
                            <th>Min Salary</th>
                            <th>Max Salary</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in Model)
                        {
                            <tr>
                                <td>@job.JobId</td>
                                <td>@job.JobTitle</td>
                                <td>@(job.MinSalary?.ToString("N2") ?? "-") TL</td>
                                <td>@(job.MaxSalary?.ToString("N2") ?? "-") TL</td>
                                <td>
                                    <a href="@Url.Action("EditJob", new { id = job.JobId })" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" asp-action="DeleteJob" asp-route-id="@job.JobId"
                                          onsubmit="return confirm('Are you sure you want to delete?')" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>