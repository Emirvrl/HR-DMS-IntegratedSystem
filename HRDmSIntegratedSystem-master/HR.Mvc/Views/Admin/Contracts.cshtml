@model List<HRDms.Data.Models.EmploymentContract>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Admin - Contract Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Contract Management</h2>
            <a href="@Url.Action("Index", "Admin")" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left"></i> Back to Admin Panel
            </a>
        </div>

        <table class="table table-striped table-bordered table-sm align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Employee</th>
                    <th>Department</th>
                    <th>Position</th>
                    <th>Type</th>
                    <th>Start</th>
                    <th>End</th>
                    <th>Active?</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.ContractId</td>
                        <td>@c.Employee?.FirstName @c.Employee?.LastName</td>
                        <td>@c.Employee?.Department?.DepartmentName</td>
                        <td>@c.Employee?.Job?.JobTitle</td>
                        <td>@c.ContractType</td>
                        <td>@c.StartDate.ToString("dd.MM.yyyy")</td>
                        <td>@(c.EndDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                        <td>
                            @if (c.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
</body>
</html>