@model HRDms.Data.Models.LeaveType
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>İzin Türü Düzenle</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light p-4">
    <div class="container">
        <div class="card">
            <div class="card-header bg-warning">
                <h3>Edit Leave Type</h3>
            </div>
            <div class="card-body">
                <form method="post">
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.LeaveTypeId)

                    <div class="mb-3">
                        <label class="form-label">Leave Type Name *</label>
                        <input asp-for="TypeName" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Year of Relationship Rights (Days)</label>
                        <input asp-for="DaysAllowed" type="number" class="form-control" />
                        <small class="text-muted">Leave it blank for unlimited permissions</small>
                    </div>

                    <button type="submit" class="btn btn-warning">Update</button>
                    <a href="@Url.Action("LeaveTypes")" class="btn btn-secondary">İptal</a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>