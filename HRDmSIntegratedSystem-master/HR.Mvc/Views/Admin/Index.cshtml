@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h3><i class="fas fa-crown"></i> Admin Dashboard</h3>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <!-- HR Employees -->
                    <div class="col-md-4">
                        <div class="card text-center h-100">
                            <div class="card-body">
                                <i class="fas fa-user-tie fa-3x text-primary mb-3"></i>
                                <h5>HR Employees</h5>
                                <p class="text-muted">@ViewBag.TotalHREmployees People</p>
                                <a href="@Url.Action("HREmployees")" class="btn btn-primary">Manage</a>
                            </div>
                        </div>
                    </div>

                    <!-- Jobs -->
                    <div class="col-md-4">
                        <div class="card text-center h-100">
                            <div class="card-body">
                                <i class="fas fa-briefcase fa-3x text-success mb-3"></i>
                                <h5>Jobs</h5>
                                <p class="text-muted">@ViewBag.TotalJobs Positions</p>
                                <a href="@Url.Action("Jobs")" class="btn btn-success">Manage</a>
                            </div>
                        </div>
                    </div>

                    <!-- Leave Types -->
                    <div class="col-md-4">
                        <div class="card text-center h-100">
                            <div class="card-body">
                                <i class="fas fa-calendar-alt fa-3x text-warning mb-3"></i>
                                <h5>Leave Types</h5>
                                <p class="text-muted">@ViewBag.TotalLeaveTypes Types</p>
                                <a href="@Url.Action("LeaveTypes")" class="btn btn-warning">Manage</a>
                            </div>
                        </div>
                    </div>

                    <!-- Locations -->
                    <div class="col-md-4">
                        <div class="card text-center h-100">
                            <div class="card-body">
                                <i class="fas fa-map-marker-alt fa-3x text-info mb-3"></i>
                                <h5>Locations</h5>
                                <p class="text-muted">@ViewBag.TotalLocations Locations</p>
                                <a href="@Url.Action("Locations")" class="btn btn-info">Manage</a>
                            </div>
                        </div>
                    </div>

                    <!-- Roles -->
                    <div class="col-md-4">
                        <div class="card text-center h-100">
                            <div class="card-body">
                                <i class="fas fa-user-shield fa-3x text-danger mb-3"></i>
                                <h5>Roles</h5>
                                <p class="text-muted">@ViewBag.TotalRoles Roles</p>
                                <a href="@Url.Action("Roles")" class="btn btn-danger">View</a>
                            </div>
                        </div>
                    </div>

                    <!-- Logout -->
                    <div class="col-md-4">
                        <div class="card text-center h-100">
                            <div class="card-body">
                                <i class="fas fa-sign-out-alt fa-3x text-secondary mb-3"></i>
                                <h5>Logout</h5>
                                <p class="text-muted">Sign out of your session</p>
                                <a href="@Url.Action("Logout", "Login")" class="btn btn-secondary">Logout</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>