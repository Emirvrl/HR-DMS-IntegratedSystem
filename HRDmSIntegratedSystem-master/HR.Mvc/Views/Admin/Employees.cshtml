@model List<HRDms.Data.Models.Employee>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Admin - Employee Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Employee Management</h2>
            <a href="@Url.Action("Index", "Admin")" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left"></i> Back to Admin Panel
            </a>
        </div>

        <table class="table table-striped table-bordered table-sm align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Department</th>
                    <th>Position</th>
                    <th>Manager</th>
                    <th>Active?</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.EmployeeId</td>
                        <td>@e.FirstName @e.LastName</td>
                        <td>@e.Department?.DepartmentName</td>
                        <td>@e.Job?.JobTitle</td>
                        <td>@(e.Manager != null ? e.Manager.FirstName + " " + e.Manager.LastName : "-")</td>
                        <td>
                            @if (e.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
</body>
</html>