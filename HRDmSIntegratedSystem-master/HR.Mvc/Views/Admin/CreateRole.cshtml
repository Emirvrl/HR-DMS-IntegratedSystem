@model HRDms.Data.Models.Role
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>New Role</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light p-4">
    <div class="container">
        <div class="card">
            <div class="card-header bg-danger text-white">
                <h3>Add New Role</h3>
            </div>
            <div class="card-body">
                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger">
                        @Html.ValidationSummary(false)
                    </div>
                }

                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Role Name *</label>
                        <input asp-for="RoleName" class="form-control" placeholder="e.g. Manager" required />
                        <small class="text-muted">Must be unique</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea asp-for="RoleDescription" class="form-control" rows="3" placeholder="Role description"></textarea>
                    </div>

                    <button type="submit" class="btn btn-danger">Save</button>
                    <a href="@Url.Action("Roles")" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>