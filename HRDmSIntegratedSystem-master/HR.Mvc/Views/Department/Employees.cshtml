@model HR.Mvc.Models.DepartmentDetailViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Department Employees</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container">
        <div class="d-flex justify-content-between mb-3">
            <div>
                <h2><i class="fas fa-building"></i> @Model.DepartmentName</h2>
                <p class="text-muted">
                    <i class="fas fa-users"></i> @Model.Employees.Count Employees
                    @if (!string.IsNullOrEmpty(Model.LocationName))
                    {
                        <span class="ms-3"><i class="fas fa-map-marker-alt"></i> @Model.LocationName</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.ManagerName))
                    {
                        <span class="ms-3"><i class="fas fa-user-tie"></i> Manager: @Model.ManagerName</span>
                    }
                </p>
            </div>
            <a href="@Url.Action("Index")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }

        @if (Model.Employees.Any())
        {
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5>Employee List</h5>
                </div>
                <div class="card-body">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Position</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Hire Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var employee in Model.Employees.OrderBy(e => e.FullName))
                            {
                                <tr>
                                    <td>@employee.EmployeeId</td>
                                    <td>@employee.FullName</td>
                                    <td>@(employee.JobTitle ?? "N/A")</td>
                                    <td>@employee.Email</td>
                                    <td>@employee.PhoneNumber</td>
                                    <td>@(employee.HireDate?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                    <td>
                                        @if (employee.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Details", "Employee", new { id = employee.EmployeeId })" class="btn btn-sm btn-info" title="View Profile">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("Index", "PerformanceReviews", new { employeeId = employee.EmployeeId, returnUrl = Url.Action("Employees", "Department", new { id = ViewBag.DepartmentId }) })" class="btn btn-sm btn-warning" title="Performance Reviews">
                                            <i class="fas fa-chart-line"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-body text-center p-5">
                    <i class="fas fa-users-slash fa-4x text-muted mb-3"></i>
                    <h4>No Employees in This Department</h4>
                    <p class="text-muted">There are no employees assigned to this department yet.</p>
                </div>
            </div>
        }
    </div>
</body>
</html>