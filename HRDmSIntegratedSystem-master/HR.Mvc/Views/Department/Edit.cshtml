@model HR.Mvc.Models.DepartmentCreateViewModel
@{
    Layout = null;
    var canChangeManager = ViewBag.CanChangeManager ?? false;
}
<!DOCTYPE html>
<html>
<head>
    <title>Edit Department</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container">
        <div class="d-flex justify-content-between mb-3">
            <h2><i class="fas fa-edit"></i> Edit Department</h2>
            <a href="@Url.Action("Index")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }

        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5>Department: @Model.DepartmentName</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.DepartmentId)

                    @if (!canChangeManager)
                    {
                        @Html.HiddenFor(m => m.ManagerId)
                    }

                    <div class="mb-3">
                        <label class="form-label">Department Name <span class="text-danger">*</span></label>
                        <input asp-for="DepartmentName" class="form-control" required />
                        <span asp-validation-for="DepartmentName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Location <span class="text-danger">*</span></label>
                        <select asp-for="LocationId" asp-items="@ViewBag.Locations" class="form-select" required>
                            <option value="">Select Location</option>
                        </select>
                        <span asp-validation-for="LocationId" class="text-danger"></span>
                    </div>

                    @if (canChangeManager)
                    {
                        <div class="mb-3">
                            <label class="form-label">Department Manager</label>
                            <select asp-for="ManagerId" asp-items="@ViewBag.Managers" class="form-select">
                                <option value="">Select Manager (Optional)</option>
                            </select>
                            <span asp-validation-for="ManagerId" class="text-danger"></span>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label">Department Manager</label>
                            <input type="text" class="form-control"
                                   value="@(Model.ManagerName ?? "Not Assigned")"
                                   disabled />
                            <div class="alert alert-warning mt-2">
                                <i class="fas fa-info-circle"></i> Only HR and Admin users can change the department manager.
                            </div>
                        </div>
                    }

                    <div class="d-flex gap-2 justify-content-end">
                        <a href="@Url.Action("Index")" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>