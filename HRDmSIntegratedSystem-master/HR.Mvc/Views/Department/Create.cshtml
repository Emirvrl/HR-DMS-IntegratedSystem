@model HR.Mvc.Models.DepartmentCreateViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Add Department</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container">
        <div class="d-flex justify-content-between mb-3">
            <h2><i class="fas fa-building"></i> Add New Department</h2>
            <a href="@Url.Action("Index")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger">
                <strong>Error!</strong> Please check the form.
                @Html.ValidationSummary(true)
            </div>
        }

        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5>Department Information</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Department Name <span class="text-danger">*</span></label>
                        <input asp-for="DepartmentName" class="form-control" placeholder="e.g., Human Resources" required />
                        <span asp-validation-for="DepartmentName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Location <span class="text-danger">*</span></label>
                        <select asp-for="LocationId" class="form-select" asp-items="@ViewBag.Locations" required>
                            <option value="">Select Location</option>
                        </select>
                        <span asp-validation-for="LocationId" class="text-danger"></span>
                    </div>

                    @* Yönetici seçimi kaldırıldı *@
                    @*
                    <div class="mb-3">
                        <label class="form-label">Manager (Optional)</label>
                        <select asp-for="ManagerId" class="form-select" asp-items="@ViewBag.Managers">
                            <option value="">Select Manager</option>
                        </select>
                        <span asp-validation-for="ManagerId" class="text-danger"></span>
                    </div>
                    *@

                    <div class="d-flex gap-2 justify-content-end">
                        <a href="@Url.Action("Index")" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save"></i> Save
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>