@model List<HR.Mvc.Models.DepartmentViewModel>
@{
    Layout = null;
    var userRole = Context.Session.GetString("UserRole");
    var isHRorAdmin = userRole == "HR" || userRole == "Admin";
    var isDeptManager = userRole == "Department Manager" || userRole == "DepManager";
}
<!DOCTYPE html>
<html>
<head>
    <title>Departments</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">
    <div class="container mt-4">
        <div class="d-flex justify-content-between mb-3">
            <h2><i class="fas fa-building"></i> Departments</h2>
            <div>
                @if (isHRorAdmin)
                {
                    <a href="@Url.Action("Create")" class="btn btn-success">
                        <i class="fas fa-plus"></i> Add
                    </a>
                    <a href="@Url.Action("Index", "HR")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back
                    </a>
                }
                else if (isDeptManager)
                {
                    <a href="@Url.Action("Index", "Employee")" class="btn btn-info">
                        <i class="fas fa-user"></i> My Profile
                    </a>
                    <a href="@Url.Action("Logout", "Login")" class="btn btn-secondary">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </a>
                }
            </div>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        @if (Model.Any())
        {
            <div class="row g-3">
                @foreach (var dept in Model)
                {
                    <div class="col-md-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <i class="fas fa-building text-primary"></i> @dept.DepartmentName
                                </h5>
                                <p class="text-muted">
                                    <i class="fas fa-map-marker-alt"></i> @(dept.LocationName ?? "No Location")
                                </p>
                                <hr />
                                <p><strong>Employees:</strong> @dept.EmployeeCount</p>
                                <p><strong>Manager:</strong> @(dept.ManagerName ?? "Not Assigned")</p>
                            </div>
                            <div class="card-footer">
                                <a href="@Url.Action("Employees", new { id = dept.DepartmentId })" class="btn btn-sm btn-primary">
                                    <i class="fas fa-users"></i> View Employees
                                </a>
                                <a href="@Url.Action("Edit", new { id = dept.DepartmentId })" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                @if (isHRorAdmin)
                                {
                                    <button type="button" class="btn btn-sm btn-danger" onclick="confirmDelete(@dept.DepartmentId, '@dept.DepartmentName')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center p-5">
                <i class="fas fa-building fa-4x text-muted mb-3"></i>
                <h4>No Departments Found</h4>
            </div>
        }
    </div>

    <!-- Delete Modal -->
    @if (isHRorAdmin)
    {
        <div class="modal fade" id="deleteModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Confirm Delete</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to delete <strong id="deptName"></strong>?</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <form id="deleteForm" method="post" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function confirmDelete(deptId, deptName) {
            document.getElementById('deptName').textContent = deptName;
            document.getElementById('deleteForm').action = '@Url.Action("Delete")/' + deptId;
            const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }
    </script>
</body>
</html>