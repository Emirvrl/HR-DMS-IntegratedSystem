@model HR.Mvc.Models.PerformanceReviewCreateViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Add Performance Review</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container" style="max-width: 700px;">
        <div class="d-flex justify-content-between mb-3">
            <h2><i class="fas fa-chart-line"></i> Add Performance Review</h2>
            <a href="@(ViewBag.ReturnUrl ?? Url.Action("Index", new { employeeId = Model.EmployeeId }))" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger">
                <strong>Error!</strong> Please check the form.
                @Html.ValidationSummary(false)
            </div>
        }

        <!-- Employee Info -->
        @if (ViewBag.EmployeeName != null)
        {
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <h5><i class="fas fa-user"></i> Employee: @ViewBag.EmployeeName</h5>
                </div>
            </div>
        }

        <!-- Form -->
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="EmployeeId" />
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5><i class="fas fa-star"></i> Performance Review Details</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="ReviewDate" class="form-label">Review Date <span class="text-danger">*</span></label>
                        <input asp-for="ReviewDate" type="date" class="form-control" required />
                        <span asp-validation-for="ReviewDate" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Score" class="form-label">Performance Score (0-100) <span class="text-danger">*</span></label>
                        <input asp-for="Score" type="number" min="0" max="100" class="form-control" required />
                        <span asp-validation-for="Score" class="text-danger"></span>
                        <div class="form-text">
                            <strong>Guidelines:</strong> 85-100: Excellent | 70-84: Good | 50-69: Average | 0-49: Needs Improvement
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label">Review Notes (Optional)</label>
                        <textarea asp-for="Notes" class="form-control" rows="4" placeholder="Enter detailed feedback and comments..."></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 justify-content-end mt-3">
                <a href="@(ViewBag.ReturnUrl ?? Url.Action("Index", new { employeeId = Model.EmployeeId }))" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save"></i> Save Review
                </button>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>