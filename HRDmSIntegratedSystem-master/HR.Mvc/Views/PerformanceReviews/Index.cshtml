@model HR.Mvc.Models.EmployeePerformanceViewModel
@{
    Layout = null;
    var reviews = Model.Reviews;
    var totalReviews = reviews.Count;
    var avgScore = reviews.Any() ? (reviews.Average(r => r.Score) ?? 0) : 0;
    var lastReview = reviews.FirstOrDefault();
    var bestScore = reviews.Any() ? reviews.Max(r => r.Score) : 0;
}
<!DOCTYPE html>
<html>
<head>
    <title>Performance Reviews - @Model.FirstName @Model.LastName</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container">
        <div class="d-flex justify-content-between mb-3">
            <div>
                <h2><i class="fas fa-chart-line"></i> Performance Reviews</h2>
                <p class="text-muted">@Model.FirstName @Model.LastName - @(Model.JobTitle ?? "No Position")</p>
            </div>
            <div>
                <a href="@Url.Action("Create", new { employeeId = Model.EmployeeId, returnUrl = ViewBag.ReturnUrl })" class="btn btn-primary me-2">
                    <i class="fas fa-plus"></i> Add Review
                </a>
                <a href="@(ViewBag.ReturnUrl ?? Url.Action("Index", "Department"))" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
            </div>
        </div>

        <!-- Statistics -->
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-list fa-3x text-primary mb-2"></i>
                        <h3>@totalReviews</h3>
                        <p class="text-muted">Total Reviews</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-star fa-3x text-warning mb-2"></i>
                        <h3>@avgScore.ToString("F1")</h3>
                        <p class="text-muted">Average Score</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-trophy fa-3x text-success mb-2"></i>
                        <h3>@bestScore</h3>
                        <p class="text-muted">Best Score</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-clock fa-3x text-info mb-2"></i>
                        <h3>@(lastReview?.ReviewDate?.ToString("dd/MM") ?? "N/A")</h3>
                        <p class="text-muted">Last Review</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Reviews List -->
        @if (reviews.Any())
        {
            <div class="row g-3">
                @foreach (var review in reviews)
                {
                    var scoreClass = review.Score >= 85 ? "success" : review.Score >= 70 ? "info" : review.Score >= 50 ? "warning" : "danger";
                    var scoreLabel = review.Score >= 85 ? "Excellent" : review.Score >= 70 ? "Good" : review.Score >= 50 ? "Average" : "Needs Improvement";

                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header bg-@scoreClass text-white d-flex justify-content-between">
                                <span><i class="fas fa-calendar"></i> @(review.ReviewDate?.ToString("dd/MM/yyyy") ?? "No Date")</span>
                                <span class="badge bg-light text-dark">@review.Score / 100</span>
                            </div>
                            <div class="card-body">
                                <h5 class="text-@scoreClass">@scoreLabel</h5>
                                <div class="progress mb-3" style="height: 20px;">
                                    <div class="progress-bar bg-@scoreClass" role="progressbar" style="width: @review.Score%">
                                        @review.Score%
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(review.ReviewerName))
                                {
                                    <p><strong>Reviewer:</strong> @review.ReviewerName</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(review.Notes))
                                {
                                    <p><strong>Notes:</strong> @review.Notes</p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-body text-center p-5">
                    <i class="fas fa-chart-line fa-4x text-muted mb-3"></i>
                    <h4>No Performance Reviews</h4>
                    <p class="text-muted">No performance reviews found for this employee.</p>
                    <a href="@Url.Action("Create", new { employeeId = Model.EmployeeId, returnUrl = ViewBag.ReturnUrl })" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Add First Review
                    </a>
                </div>
            </div>
        }
    </div>
</body>
</html>