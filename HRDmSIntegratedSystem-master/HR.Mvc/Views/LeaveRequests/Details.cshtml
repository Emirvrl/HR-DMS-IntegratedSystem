@model HR.Mvc.Models.LeaveRequestViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Leave Request Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container" style="max-width: 1000px;">
        <div class="d-flex justify-content-between mb-3">
            <h2><i class="fas fa-calendar-check"></i> Leave Request Details #@Model.RequestId</h2>
            <a href="@Url.Action("Index")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        @{
            var days = (Model.EndDate - Model.StartDate).Days + 1;
        }

        <!-- Status Card -->
        <div class="card mb-3">
            <div class="card-header bg-@(Model.Status == "Approved" ? "success" : Model.Status == "Pending" ? "warning" : "danger") text-white">
                <h4 class="mb-0">
                    @if (Model.Status == "Approved")
                    {
                        <i class="fas fa-check-circle"></i> <span>Approved</span>
                    }
                    else if (Model.Status == "Pending")
                    {
                        <i class="fas fa-clock"></i> <span>Pending</span>
                    }
                    else
                    {
                        <i class="fas fa-times-circle"></i> <span>Rejected</span>
                    }
                </h4>
            </div>
        </div>

        <!-- Actions -->
        @if (Model.Status == "Pending")
        {
            <div class="card mb-3">
                <div class="card-body">
                    <form method="post" asp-action="Approve" asp-route-id="@Model.RequestId" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success" onclick="return confirm('Approve this request?')">
                            <i class="fas fa-check"></i> Approve
                        </button>
                    </form>
                    <form method="post" asp-action="Reject" asp-route-id="@Model.RequestId" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Reject this request?')">
                            <i class="fas fa-times"></i> Reject
                        </button>
                    </form>
                </div>
            </div>
        }

        <div class="row g-3">
            <!-- Employee Info -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white">
                        <h5><i class="fas fa-user"></i> Employee Information</h5>
                    </div>
                    <div class="card-body">
                        <p><strong>Name:</strong> @Model.EmployeeFirstName @Model.EmployeeLastName</p>
                        <p><strong>ID:</strong> @Model.EmployeeId</p>
                        <p><strong>Department:</strong> @(Model.DepartmentName ?? "N/A")</p>
                        <p><strong>Position:</strong> @(Model.JobTitle ?? "N/A")</p>
                        <p><strong>Email:</strong> @(Model.Email ?? "N/A")</p>
                    </div>
                </div>
            </div>

            <!-- Leave Details -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-info text-white">
                        <h5><i class="fas fa-calendar-alt"></i> Leave Details</h5>
                    </div>
                    <div class="card-body">
                        <p><strong>Leave Type:</strong> @(Model.LeaveTypeName ?? "N/A")</p>
                        <p><strong>Start Date:</strong> @Model.StartDate.ToString("dd/MM/yyyy")</p>
                        <p><strong>End Date:</strong> @Model.EndDate.ToString("dd/MM/yyyy")</p>
                        <p><strong>Duration:</strong> @days days</p>
                        <p><strong>Status:</strong>
                            @if (Model.Status == "Approved")
                            {
                                <span class="badge bg-success">Approved</span>
                            }
                            else if (Model.Status == "Pending")
                            {
                                <span class="badge bg-warning">Pending</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Rejected</span>
                            }
                        </p>
                    </div>
                </div>
            </div>

            <!-- Reason -->
            @if (!string.IsNullOrEmpty(Model.Reason))
            {
                <div class="col-12">
                    <div class="card">
                        <div class="card-header bg-warning">
                            <h5><i class="fas fa-comment-alt"></i> Reason</h5>
                        </div>
                        <div class="card-body">
                            <p>@Model.Reason</p>
                        </div>
                    </div>
                </div>
            }

            <!-- Approval Info -->
            @if (!string.IsNullOrEmpty(Model.ApprovedByUserName))
            {
                <div class="col-12">
                    <div class="card">
                        <div class="card-header bg-secondary text-white">
                            <h5><i class="fas fa-user-check"></i> Approval Information</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>@(Model.Status == "Approved" ? "Approved" : "Rejected") By:</strong> @Model.ApprovedByUserName</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</body>
</html>