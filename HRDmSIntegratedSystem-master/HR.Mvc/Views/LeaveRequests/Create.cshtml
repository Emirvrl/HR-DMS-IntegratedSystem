@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Create Leave Request</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container" style="max-width: 800px;">
        <div class="d-flex justify-content-between mb-3">
            <h2><i class="fas fa-calendar-plus"></i> Create Leave Request</h2>
            <a href="@Url.Action("Index", "Employee")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <!-- Employee Info -->
        @if (ViewBag.Employee != null)
        {
            var employee = ViewBag.Employee;
            <div class="card mb-3">
                <div class="card-header bg-success text-white">
                    <h5>@employee.FirstName @employee.LastName</h5>
                    <small>@(employee.Department?.DepartmentName ?? "N/A") | @(employee.Job?.JobTitle ?? "N/A")</small>
                </div>
            </div>
        }

        <!-- Form -->
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <!-- Leave Type Selection -->
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <h5><i class="fas fa-tag"></i> Select Leave Type</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.LeaveTypes != null)
                    {
                        @foreach (var leaveType in ViewBag.LeaveTypes)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="leaveTypeId" value="@leaveType.LeaveTypeId" id="leave_@leaveType.LeaveTypeId" required />
                                <label class="form-check-label" for="leave_@leaveType.LeaveTypeId">
                                    <strong>@leaveType.TypeName</strong>
                                    @if (leaveType.DaysAllowed != null)
                                    {
                                        <span class="text-muted">- Annual Allowance: @leaveType.DaysAllowed days</span>
                                    }
                                </label>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Dates -->
            <div class="card mb-3">
                <div class="card-header bg-info text-white">
                    <h5><i class="fas fa-calendar-alt"></i> Leave Dates</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Start Date <span class="text-danger">*</span></label>
                            <input type="date" name="startDate" id="startDate" class="form-control" required min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">End Date <span class="text-danger">*</span></label>
                            <input type="date" name="endDate" id="endDate" class="form-control" required min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-12">
                            <div class="alert alert-info" id="dateInfo" style="display: none;">
                                <i class="fas fa-info-circle"></i> <span id="dateDuration"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Reason -->
            <div class="card mb-3">
                <div class="card-header bg-warning">
                    <h5><i class="fas fa-comment-alt"></i> Reason (Optional)</h5>
                </div>
                <div class="card-body">
                    <textarea name="reason" class="form-control" rows="4" placeholder="Briefly explain your leave reason..."></textarea>
                </div>
            </div>

            <!-- Submit -->
            <div class="d-flex gap-2 justify-content-end">
                <a href="@Url.Action("Index", "Employee")" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-paper-plane"></i> Submit Request
                </button>
            </div>
        </form>
    </div>

    <script>
        const startDateInput = document.getElementById('startDate');
        const endDateInput = document.getElementById('endDate');
        const dateInfo = document.getElementById('dateInfo');
        const dateDuration = document.getElementById('dateDuration');

        function calculateDays() {
            const startDate = new Date(startDateInput.value);
            const endDate = new Date(endDateInput.value);

            if (startDate && endDate && startDate <= endDate) {
                const diffTime = Math.abs(endDate - startDate);
                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;
                dateInfo.style.display = 'block';
                dateDuration.textContent = `Total ${diffDays} days leave requested`;
            } else {
                dateInfo.style.display = 'none';
            }
        }

        startDateInput.addEventListener('change', function() {
            endDateInput.min = this.value;
            calculateDays();
        });
        endDateInput.addEventListener('change', calculateDays);
    </script>
</body>
</html>