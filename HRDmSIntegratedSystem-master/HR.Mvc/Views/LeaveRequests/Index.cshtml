@model List<HR.Mvc.Models.LeaveRequestViewModel>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Leave Requests Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container-fluid">
        <div class="d-flex justify-content-between mb-3">
            <h2><i class="fas fa-calendar-check"></i> Leave Requests Management</h2>
            <a href="@Url.Action("Index", "HR")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <!-- Filters -->
        <form method="get" class="card mb-3">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Status</label>
                        <select name="status" class="form-select">
                            <option value="">All Statuses</option>
                            <option value="Pending" selected="@(ViewBag.CurrentStatus == "Pending")">Pending</option>
                            <option value="Approved" selected="@(ViewBag.CurrentStatus == "Approved")">Approved</option>
                            <option value="Rejected" selected="@(ViewBag.CurrentStatus == "Rejected")">Rejected</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Employee</label>
                        <select name="employeeId" class="form-select">
                            <option value="">All Employees</option>
                            @if (ViewBag.Employees != null)
                            {
                                @foreach (var emp in ViewBag.Employees)
                                {
                                    <option value="@emp.EmployeeId" selected="@(ViewBag.CurrentEmployeeId == emp.EmployeeId)">@emp.FullName</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-filter"></i> Filter
                        </button>
                    </div>
                </div>
            </div>
        </form>

        <!-- Statistics -->
        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-list fa-3x text-primary mb-2"></i>
                        <h3>@ViewBag.TotalRequests</h3>
                        <p class="text-muted">Total</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-clock fa-3x text-warning mb-2"></i>
                        <h3>@ViewBag.PendingRequests</h3>
                        <p class="text-muted">Pending</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-check-circle fa-3x text-success mb-2"></i>
                        <h3>@ViewBag.ApprovedRequests</h3>
                        <p class="text-muted">Approved</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-times-circle fa-3x text-danger mb-2"></i>
                        <h3>@ViewBag.RejectedRequests</h3>
                        <p class="text-muted">Rejected</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Table -->
        @if (Model.Any())
        {
            <div class="card">
                <div class="card-body">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Employee</th>
                                <th>Leave Type</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Days</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var leave in Model)
                            {
                                var days = (leave.EndDate - leave.StartDate).Days + 1;

                                <tr>
                                    <td>#@leave.RequestId</td>
                                    <td>
                                        <strong>@leave.EmployeeFirstName @leave.EmployeeLastName</strong><br />
                                        <small class="text-muted">@(leave.DepartmentName ?? "N/A")</small>
                                    </td>
                                    <td>@(leave.LeaveTypeName ?? "N/A")</td>
                                    <td>@leave.StartDate.ToString("dd/MM/yyyy")</td>
                                    <td>@leave.EndDate.ToString("dd/MM/yyyy")</td>
                                    <td><strong>@days</strong> days</td>
                                    <td>
                                        @if (leave.Status == "Approved")
                                        {
                                            <span class="badge bg-success">Approved</span>
                                        }
                                        else if (leave.Status == "Pending")
                                        {
                                            <span class="badge bg-warning">Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Rejected</span>
                                        }
                                    </td>
                                    <td>
                                        @if (leave.Status == "Pending")
                                        {
                                            <form method="post" asp-action="Approve" asp-route-id="@leave.RequestId" style="display: inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Approve this request?')">
                                                    <i class="fas fa-check"></i>
                                                </button>
                                            </form>
                                            <form method="post" asp-action="Reject" asp-route-id="@leave.RequestId" style="display: inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Reject this request?')">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </form>
                                        }
                                        <a href="@Url.Action("Details", new { id = leave.RequestId })" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-body text-center p-5">
                    <i class="fas fa-calendar-times fa-4x text-muted mb-3"></i>
                    <h4>No Leave Requests Found</h4>
                    <p class="text-muted">No leave requests match the selected filters.</p>
                </div>
            </div>
        }
    </div>
</body>
</html>