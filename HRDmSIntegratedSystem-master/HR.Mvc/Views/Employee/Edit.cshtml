@model HRDms.Data.Models.Employee
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Edit Employee</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container">
        <div class="d-flex justify-content-between mb-3">
            <h2><i class="fas fa-user-edit"></i> Edit Employee</h2>
            <a href="@Url.Action("Index", "HR")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger">
                <strong>Error!</strong> Please check the form.
                @Html.ValidationSummary(false)
            </div>
        }

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.EmployeeId)
            @Html.HiddenFor(m => m.UserId)

            <!-- Personal Information -->
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <h5><i class="fas fa-user"></i> Personal Information</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">First Name <span class="text-danger">*</span></label>
                            <input asp-for="FirstName" class="form-control" required />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Last Name <span class="text-danger">*</span></label>
                            <input asp-for="LastName" class="form-control" required />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Identity Number <span class="text-danger">*</span></label>
                            <input asp-for="IdentityNumber" class="form-control" maxlength="11" required />
                            <span asp-validation-for="IdentityNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Work Information -->
            <div class="card mb-3">
                <div class="card-header bg-success text-white">
                    <h5><i class="fas fa-briefcase"></i> Work Information</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Hire Date <span class="text-danger">*</span></label>
                            <input asp-for="HireDate" type="date" class="form-control" required />
                            <span asp-validation-for="HireDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Department <span class="text-danger">*</span></label>
                            @{
                                var isDepartmentManager = ViewBag.IsDepartmentManager as bool? ?? false;
                            }
                            @if (isDepartmentManager)
                            {
                                <select asp-for="DepartmentId" asp-items="@((List<SelectListItem>)ViewBag.Departments)" class="form-select" disabled>
                                    <option value="">Select Department</option>
                                </select>
                                @Html.HiddenFor(m => m.DepartmentId)
                                <small class="text-muted">
                                    <i class="fas fa-info-circle"></i> Cannot change department for department managers.
                                </small>
                            }
                            else
                            {
                                <select asp-for="DepartmentId" asp-items="@((List<SelectListItem>)ViewBag.Departments)" class="form-select" required>
                                    <option value="">Select Department</option>
                                </select>
                            }
                            <span asp-validation-for="DepartmentId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Position <span class="text-danger">*</span></label>
                            <select asp-for="JobId" asp-items="@((List<SelectListItem>)ViewBag.Jobs)" class="form-select" required>
                                <option value="">Select Position</option>
                            </select>
                            <span asp-validation-for="JobId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mt-4">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label class="form-check-label">Active Employee</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contract Update -->
            @if (ViewBag.ActiveContract != null)
            {
                var contract = (HRDms.Data.Models.EmploymentContract)ViewBag.ActiveContract;
                <div class="card mb-3">
                    <div class="card-header bg-info text-white">
                        <h5><i class="fas fa-file-contract"></i> Employment Contract</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="updateContractCheck" name="updateContract" value="true">
                            <label class="form-check-label" for="updateContractCheck">
                                Update contract information
                            </label>
                        </div>

                        <div id="contractSection" style="display:none;">
                            <input type="hidden" name="contractId" value="@contract.ContractId" />
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Start Date <span class="text-danger">*</span></label>
                                    <input type="date" name="contractStartDate" id="contractStartDate" class="form-control" value="@contract.StartDate.ToString("yyyy-MM-dd")" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">End Date</label>
                                    <input type="date" name="contractEndDate" class="form-control" value="@(contract.EndDate?.ToString("yyyy-MM-dd"))" />
                                    <small class="text-muted">Leave empty for indefinite contract</small>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Salary (TL) <span class="text-danger">*</span></label>
                                    <input type="number" name="contractSalary" id="contractSalary" class="form-control" step="0.01" min="0" value="@contract.Salary" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Contract Type</label>
                                    <select name="contractType" class="form-select">
                                        <option value="Belirsiz Süreli" selected="@(contract.ContractType == "Belirsiz Süreli")">Indefinite Term</option>
                                        <option value="Belirli Süreli" selected="@(contract.ContractType == "Belirli Süreli")">Fixed Term</option>
                                        <option value="Kısmi Zamanlı" selected="@(contract.ContractType == "Kısmi Zamanlı")">Part Time</option>
                                        <option value="Proje Bazlı" selected="@(contract.ContractType == "Proje Bazlı")">Project Based</option>
                                        <option value="Stajyer" selected="@(contract.ContractType == "Stajyer")">Internship</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Submit Buttons -->
            <div class="d-flex gap-2 justify-content-end">
                <a href="@Url.Action("Index", "HR")" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Save Changes
                </button>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('updateContractCheck')?.addEventListener('change', function() {
            const section = document.getElementById('contractSection');
            const startDate = document.getElementById('contractStartDate');
            const salary = document.getElementById('contractSalary');

            if (this.checked) {
                section.style.display = 'block';
                startDate.required = true;
                salary.required = true;
            } else {
                section.style.display = 'none';
                startDate.required = false;
                salary.required = false;
            }
        });
    </script>
</body>
</html>