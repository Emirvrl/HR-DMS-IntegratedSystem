@model HR.Mvc.Models.EmployeeDashboardViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Employee Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">
    <div class="container mt-4">
        <!-- Header -->
        <div class="card mb-4 shadow">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <div>
                    <h3><i class="fas fa-user-circle"></i> Welcome, @Model.FirstName @Model.LastName</h3>
                    <small>@(Model.JobTitle ?? "No Position") | @(Model.DepartmentName ?? "No Department")</small>
                </div>
                <a href="@Url.Action("Logout", "Login")" class="btn btn-sm btn-light">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </div>

        <!-- Statistics -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-calendar-check fa-3x text-primary mb-2"></i>
                        <h3>@Model.TotalLeaveRequests</h3>
                        <p class="text-muted">Total Leave Requests</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-clock fa-3x text-warning mb-2"></i>
                        <h3>@Model.PendingLeaveRequests</h3>
                        <p class="text-muted">Pending</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-user-check fa-3x text-success mb-2"></i>
                        <h3>@Model.CurrentMonthAttendance</h3>
                        <p class="text-muted">This Month Attendance</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-star fa-3x text-info mb-2"></i>
                        <h3>@Model.PerformanceReviews</h3>
                        <p class="text-muted">Performance Reviews</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h5><i class="fas fa-bolt"></i> Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <a href="@Url.Action("Details", new { id = Model.EmployeeId })" class="btn btn-outline-primary w-100">
                            <i class="fas fa-user"></i> My Profile
                        </a>
                    </div>
                    <div class="col-md-3">
                        <a href="@Url.Action("Leaves", new { id = Model.EmployeeId })" class="btn btn-outline-warning w-100">
                            <i class="fas fa-calendar"></i> Leave Requests
                        </a>
                    </div>
                    <div class="col-md-3">
                        <a href="@Url.Action("Attendance", new { id = Model.EmployeeId })" class="btn btn-outline-success w-100">
                            <i class="fas fa-clock"></i> Attendance
                        </a>
                    </div>
                    <div class="col-md-3">
                        <a href="@Url.Action("Performance", new { id = Model.EmployeeId })" class="btn btn-outline-info w-100">
                            <i class="fas fa-star"></i> My Performance
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Leave Requests -->
        <div class="card">
            <div class="card-header bg-warning">
                <h5><i class="fas fa-history"></i> Recent Leave Requests</h5>
            </div>
            <div class="card-body">
                @if (Model.RecentLeaveRequests != null && Model.RecentLeaveRequests.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var leave in Model.RecentLeaveRequests)
                            {
                                <tr>
                                    <td>@(leave.TypeName ?? "N/A")</td>
                                    <td>@leave.StartDate.ToString("dd/MM/yyyy")</td>
                                    <td>@leave.EndDate.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (leave.Status == "Approved")
                                        {
                                            <span class="badge bg-success">Approved</span>
                                        }
                                        else if (leave.Status == "Pending")
                                        {
                                            <span class="badge bg-warning">Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Rejected</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted text-center">No leave requests found</p>
                }
            </div>
        </div>
    </div>
</body>
</html>