@model HR.Mvc.Models.EmployeeDetailsViewModel
@{
    Layout = null;
    var userRole = Context.Session.GetString("UserRole");
    var sessionEmployeeId = Context.Session.GetInt32("EmployeeId");
    var isHRorAdmin = userRole == "HR" || userRole == "Admin";
    var isDeptManager = userRole == "Department Manager";
    var isSelfView = sessionEmployeeId == Model.EmployeeId;

    string backUrl;
    if (isDeptManager && isSelfView)
    {
        backUrl = Url.Action("Index", "Employee");
    }
    else if (isDeptManager && !isSelfView)
    {
        backUrl = Url.Action("Index", "Department");
    }
    else if (isHRorAdmin)
    {
        backUrl = Url.Action("Index", "HR");
    }
    else
    {
        backUrl = Url.Action("Index", "Employee");
    }
}
<!DOCTYPE html>
<html>
<head>
    <title>Employee Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container">
        <div class="d-flex justify-content-between mb-3">
            <h2><i class="fas fa-user"></i> Employee Details</h2>
            <a href="@backUrl" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <!-- Profile Card -->
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">@Model.FirstName @Model.LastName</h4>
                    <div>
                        @if (Model.IsActive == true)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Employee ID:</strong> @Model.EmployeeId</p>
                        <p><strong>Position:</strong> @(Model.JobTitle ?? "Not Specified")</p>
                        <p><strong>Department:</strong> @(Model.DepartmentName ?? "Not Specified")</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Hire Date:</strong> @(Model.HireDate?.ToString("dd/MM/yyyy") ?? "Not Specified")</p>
                        @if (Model.HireDate.HasValue)
                        {
                            var days = (DateTime.Now - Model.HireDate.Value).Days;
                            <p><strong>Tenure:</strong> @days days</p>
                        }
                    </div>
                </div>

                @if (isHRorAdmin)
                {
                    <div class="mt-3">
                        <a href="@Url.Action("Edit", "Employee", new { id = Model.EmployeeId })" class="btn btn-warning">
                            <i class="fas fa-edit"></i> Edit
                        </a>
                        <button type="button" class="btn btn-danger" onclick="confirmDelete(@Model.EmployeeId, '@Model.FirstName @Model.LastName')">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    </div>
                }
                else if (isSelfView && isDeptManager)
                {
                    <div class="alert alert-info mt-3">
                        <i class="fas fa-info-circle"></i> You are viewing your own profile.
                        <a href="@Url.Action("Index", "Department")" class="btn btn-sm btn-primary ms-2">
                            <i class="fas fa-building"></i> Go to Department Account
                        </a>
                    </div>
                }
            </div>
        </div>

        <!-- Contact Information -->
        <div class="card mb-3">
            <div class="card-header bg-secondary text-white">
                <h5><i class="fas fa-address-card"></i> Contact Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p>
                            <strong>Email:</strong>
                            @if (!string.IsNullOrEmpty(Model.Email))
                            {
                                <a href="mailto:@Model.Email">@Model.Email</a>
                            }
                            else
                            {
                                <span class="text-muted">Not Specified</span>
                            }
                        </p>
                    </div>
                    <div class="col-md-6">
                        <p>
                            <strong>Phone:</strong>
                            @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                            {
                                <a href="tel:@Model.PhoneNumber">@Model.PhoneNumber</a>
                            }
                            else
                            {
                                <span class="text-muted">Not Specified</span>
                            }
                        </p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Identity Number:</strong> @(Model.IdentityNumber ?? "Not Specified")</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Manager Information -->
        @if (!string.IsNullOrEmpty(Model.ManagerFirstName))
        {
            <div class="card mb-3">
                <div class="card-header bg-info text-white">
                    <h5><i class="fas fa-user-tie"></i> Manager Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>Name:</strong> @Model.ManagerFirstName @Model.ManagerLastName</p>
                    <p><strong>Position:</strong> @(Model.ManagerJobTitle ?? "Manager")</p>
                    @if (!string.IsNullOrEmpty(Model.ManagerEmail))
                    {
                        <p><strong>Email:</strong> <a href="mailto:@Model.ManagerEmail">@Model.ManagerEmail</a></p>
                    }
                </div>
            </div>
        }

        <!-- Employment Contract -->
        @if (Model.ActiveContract != null)
        {
            <div class="card mb-3">
                <div class="card-header bg-success text-white">
                    <h5><i class="fas fa-file-contract"></i> Active Employment Contract</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <p><strong>Type:</strong> @Model.ActiveContract.ContractType</p>
                        </div>
                        <div class="col-md-3">
                            <p><strong>Start Date:</strong> @(Model.ActiveContract.StartDate?.ToString("dd/MM/yyyy") ?? "-")</p>
                        </div>
                        <div class="col-md-3">
                            <p>
                                <strong>End Date:</strong>
                                @if (Model.ActiveContract.EndDate.HasValue)
                                {
                                    @Model.ActiveContract.EndDate.Value.ToString("dd/MM/yyyy")
                                }
                                else
                                {
                                    <span class="text-success">Indefinite</span>
                                }
                            </p>
                        </div>
                        <div class="col-md-3">
                            <p><strong>Salary:</strong> @(Model.ActiveContract.Salary?.ToString("N2") ?? "0.00") TL</p>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Delete Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete <strong id="employeeName"></strong>?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form id="deleteForm" method="post" action="@Url.Action("Delete", "Employee", new { id = Model.EmployeeId })" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function confirmDelete(employeeId, employeeName) {
            document.getElementById('employeeName').textContent = employeeName;
            const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }
    </script>
</body>
</html>