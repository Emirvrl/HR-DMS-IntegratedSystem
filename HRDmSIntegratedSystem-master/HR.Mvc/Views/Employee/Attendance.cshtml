@model HR.Mvc.Models.EmployeeAttendanceViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Attendance Records</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container">
        @{
            var userRole = Context.Session.GetString("UserRole");
            var isHRorAdmin = userRole == "HR" || userRole == "Admin";
            var backUrl = isHRorAdmin ? Url.Action("Index", "HR") : Url.Action("Index", "Employee");
            
            var today = DateTime.Today;
            var todayAttendance = Model.Attendances?.FirstOrDefault(a => a.Date.HasValue && a.Date.Value.Date == today);
        }

        <div class="d-flex justify-content-between mb-3">
            <h2><i class="fas fa-calendar-check"></i> Attendance Records</h2>
            <a href="@backUrl" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <!-- Employee Info -->
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <h4>@Model.FirstName @Model.LastName</h4>
                <small>@(Model.JobTitle ?? "No Position") | @(Model.DepartmentName ?? "No Department")</small>
            </div>
            <div class="card-body">
                @if (!isHRorAdmin)
                {
                    @if (todayAttendance == null)
                    {
                        <form asp-action="CheckIn" asp-controller="Employee" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="employeeId" value="@Model.EmployeeId" />
                            <button type="submit" class="btn btn-success btn-lg w-100">
                                <i class="fas fa-sign-in-alt"></i> Check In
                            </button>
                        </form>
                    }
                    else if (todayAttendance.CheckOutTime == null)
                    {
                        <form asp-action="CheckOut" asp-controller="Employee" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="employeeId" value="@Model.EmployeeId" />
                            <input type="hidden" name="attendanceId" value="@todayAttendance.AttendanceId" />
                            <button type="submit" class="btn btn-danger btn-lg w-100">
                                <i class="fas fa-sign-out-alt"></i> Check Out
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-success text-center">
                            <i class="fas fa-check-circle"></i> You have completed your attendance for today.
                        </div>
                    }
                }
                else
                {
                     <div class="alert alert-info text-center">
                        <i class="fas fa-info-circle"></i> Viewing as HR/Admin
                    </div>
                }
            </div>
        </div>

        <!-- Statistics -->
        @{
            var totalDays = Model.Attendances?.Count ?? 0;
            var completedDays = Model.Attendances?.Count(a => a.CheckOutTime != null) ?? 0;
            var incompleteDays = totalDays - completedDays;
            var currentMonth = DateTime.Now.Month;
            var currentYear = DateTime.Now.Year;
            var thisMonthDays = Model.Attendances?.Count(a => a.Date.HasValue && a.Date.Value.Month == currentMonth && a.Date.Value.Year == currentYear) ?? 0;
        }

        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-calendar-check fa-3x text-primary mb-2"></i>
                        <h3>@totalDays</h3>
                        <p class="text-muted">Total Days</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-check-double fa-3x text-success mb-2"></i>
                        <h3>@completedDays</h3>
                        <p class="text-muted">Full Days</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-clock fa-3x text-warning mb-2"></i>
                        <h3>@incompleteDays</h3>
                        <p class="text-muted">Incomplete</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-calendar-day fa-3x text-info mb-2"></i>
                        <h3>@thisMonthDays</h3>
                        <p class="text-muted">This Month</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Attendance Table -->
        <div class="card">
            <div class="card-header bg-secondary text-white">
                <h5><i class="fas fa-history"></i> Attendance History</h5>
            </div>
            <div class="card-body">
                @if (Model.Attendances != null && Model.Attendances.Any())
                {
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Check In</th>
                                <th>Check Out</th>
                                <th>Duration</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var attendance in Model.Attendances.OrderByDescending(a => a.Date))
                            {
                                <tr>
                                    <td>@(attendance.Date?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td>
                                        @if (attendance.CheckInTime != null)
                                        {
                                            <span class="text-success">@attendance.CheckInTime.Value.ToString("HH:mm")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (attendance.CheckOutTime != null)
                                        {
                                            <span class="text-primary">@attendance.CheckOutTime.Value.ToString("HH:mm")</span>
                                        }
                                        else
                                        {
                                            <span class="text-warning">Not checked out</span>
                                        }
                                    </td>
                                    <td>
                                        @if (attendance.CheckInTime != null && attendance.CheckOutTime != null)
                                        {
                                            var duration = attendance.CheckOutTime.Value - attendance.CheckInTime.Value;
                                            <span>@($"{(int)duration.TotalHours}h {duration.Minutes}m")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (attendance.CheckOutTime != null)
                                        {
                                            <span class="badge bg-success">Complete</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Ongoing</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center p-5">
                        <i class="fas fa-calendar-times fa-4x text-muted mb-3"></i>
                        <h4>No Attendance Records Yet</h4>
                        <p class="text-muted">Check in to create your first record</p>
                    </div>
                }
            </div>
        </div>
    </div>
</body>
</html>
