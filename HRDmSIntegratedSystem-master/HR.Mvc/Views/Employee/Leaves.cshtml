@model HR.Mvc.Models.EmployeeLeavesViewModel
@{
    Layout = null;
    var userRole = Context.Session.GetString("UserRole");
    var isHRorAdmin = userRole == "HR" || userRole == "Admin";
    var backUrl = isHRorAdmin ? Url.Action("Index", "HR") : Url.Action("Index", "Employee");
}
<!DOCTYPE html>
<html>
<head>
    <title>Leave Requests</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container">
        <div class="d-flex justify-content-between mb-3">
            <h2><i class="fas fa-calendar-alt"></i> Leave Requests</h2>
            <div>
                @if (!isHRorAdmin)
                {
                    <a href="@Url.Action("Create", "LeaveRequests")" class="btn btn-primary me-2">
                        <i class="fas fa-plus"></i> New Request
                    </a>
                }
                <a href="@backUrl" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
            </div>
        </div>

        <!-- Employee Info -->
        <div class="card mb-3">
            <div class="card-header bg-success text-white">
                <h4>@Model.FirstName @Model.LastName</h4>
                <small>@(Model.JobTitle ?? "No Position") | ID: @Model.EmployeeId</small>
            </div>
        </div>

        <!-- Statistics -->
        @{
            var leaves = Model.LeaveRequests;
            var totalLeaves = leaves.Count;
            var approvedLeaves = leaves.Count(l => l.Status == "Approved");
            var pendingLeaves = leaves.Count(l => l.Status == "Pending");
            var totalDays = leaves.Where(l => l.Status == "Approved").Sum(l => (l.EndDate - l.StartDate).Days + 1);
        }

        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-list fa-3x text-primary mb-2"></i>
                        <h3>@totalLeaves</h3>
                        <p class="text-muted">Total Requests</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-check-circle fa-3x text-success mb-2"></i>
                        <h3>@approvedLeaves</h3>
                        <p class="text-muted">Approved</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-clock fa-3x text-warning mb-2"></i>
                        <h3>@pendingLeaves</h3>
                        <p class="text-muted">Pending</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-calendar-day fa-3x text-info mb-2"></i>
                        <h3>@totalDays</h3>
                        <p class="text-muted">Days Used</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Leave Requests -->
        @if (leaves.Any())
        {
            <div class="row g-3">
                @foreach (var leave in leaves)
                {
                    var days = (leave.EndDate - leave.StartDate).Days + 1;

                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <strong>@(leave.LeaveTypeName ?? "Leave")</strong>
                                @if (leave.Status == "Approved")
                                {
                                    <span class="badge bg-success">Approved</span>
                                }
                                else if (leave.Status == "Pending")
                                {
                                    <span class="badge bg-warning">Pending</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Rejected</span>
                                }
                            </div>
                            <div class="card-body">
                                <p><strong>Start:</strong> @leave.StartDate.ToString("dd/MM/yyyy")</p>
                                <p><strong>End:</strong> @leave.EndDate.ToString("dd/MM/yyyy")</p>
                                <p><strong>Duration:</strong> @days days</p>
                                @if (!string.IsNullOrEmpty(leave.Reason))
                                {
                                    <p><strong>Reason:</strong> @leave.Reason</p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-body text-center p-5">
                    <i class="fas fa-calendar-times fa-4x text-muted mb-3"></i>
                    <h4>No Leave Requests</h4>
                    <p class="text-muted">No leave requests found for this employee.</p>
                </div>
            </div>
        }
    </div>
</body>
</html>