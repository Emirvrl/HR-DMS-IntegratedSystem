@model HRDms.Data.Models.Employee
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Add New Employee</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container">
        <div class="d-flex justify-content-between mb-3">
            <h2><i class="fas fa-user-plus"></i> Add New Employee</h2>
            <a href="@Url.Action("Index", "HR")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger">
                <strong>Error!</strong> Please check the form.
                @Html.ValidationSummary(true)
            </div>
        }

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <!-- Personal Information -->
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <h5><i class="fas fa-user"></i> Personal Information</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">First Name <span class="text-danger">*</span></label>
                            <input asp-for="FirstName" class="form-control" required />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Last Name <span class="text-danger">*</span></label>
                            <input asp-for="LastName" class="form-control" required />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Identity Number <span class="text-danger">*</span></label>
                            <input asp-for="IdentityNumber" class="form-control" maxlength="11" required />
                            <span asp-validation-for="IdentityNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Work Information -->
            <div class="card mb-3">
                <div class="card-header bg-success text-white">
                    <h5><i class="fas fa-briefcase"></i> Work Information</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Hire Date <span class="text-danger">*</span></label>
                            <input asp-for="HireDate" type="date" class="form-control" required />
                            <span asp-validation-for="HireDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Department <span class="text-danger">*</span></label>
                            <select asp-for="DepartmentId" class="form-select" required>
                                <option value="">Select Department</option>
                                @foreach (var dept in ViewBag.Departments)
                                {
                                    <option value="@dept.DepartmentId">@dept.DepartmentName</option>
                                }
                            </select>
                            <span asp-validation-for="DepartmentId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Position <span class="text-danger">*</span></label>
                            <select asp-for="JobId" class="form-select" required>
                                <option value="">Select Position</option>
                                @foreach (var job in ViewBag.Jobs)
                                {
                                    <option value="@job.JobId">@job.JobTitle</option>
                                }
                            </select>
                            <span asp-validation-for="JobId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mt-4">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                                <label class="form-check-label">Active Employee</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- User Account -->
            <div class="card mb-3">
                <div class="card-header bg-warning">
                    <h5><i class="fas fa-user-lock"></i> User Account (Required)</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i> User account is mandatory for every employee.
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Username <span class="text-danger">*</span></label>
                            <input type="text" name="username" id="username" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Password <span class="text-danger">*</span></label>
                            <input type="password" name="userPassword" class="form-control" required />
                        </div>
                    </div>
                    <input type="hidden" name="createUser" value="true" />
                </div>
            </div>

            <!-- Employment Contract -->
            <div class="card mb-3">
                <div class="card-header bg-info text-white">
                    <h5><i class="fas fa-file-contract"></i> Employment Contract (Optional)</h5>
                </div>
                <div class="card-body">
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="createContractCheck" name="createContract" value="true">
                        <label class="form-check-label" for="createContractCheck">
                            Create employment contract for this employee
                        </label>
                    </div>

                    <div id="contractSection" style="display:none;">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Contract Start Date <span class="text-danger">*</span></label>
                                <input type="date" name="contractStartDate" id="contractStartDate" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Contract End Date</label>
                                <input type="date" name="contractEndDate" class="form-control" />
                                <small class="text-muted">Leave empty for indefinite contract</small>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Salary (TL) <span class="text-danger">*</span></label>
                                <input type="number" name="contractSalary" id="contractSalary" class="form-control" step="0.01" min="0" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Contract Type</label>
                                <select name="contractType" class="form-select">
                                    <option value="Belirsiz Süreli">Indefinite Term</option>
                                    <option value="Belirli Süreli">Fixed Term</option>
                                    <option value="Kısmi Zamanlı">Part Time</option>
                                    <option value="Proje Bazlı">Project Based</option>
                                    <option value="Stajyer">Internship</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Submit Buttons -->
            <div class="d-flex gap-2 justify-content-end">
                <a href="@Url.Action("Index", "HR")" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Save
                </button>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Contract section toggle
        document.getElementById('createContractCheck').addEventListener('change', function() {
            const section = document.getElementById('contractSection');
            const startDate = document.getElementById('contractStartDate');
            const salary = document.getElementById('contractSalary');

            if (this.checked) {
                section.style.display = 'block';
                startDate.required = true;
                salary.required = true;

                // Auto-fill start date from hire date
                const hireDate = document.querySelector('input[name="HireDate"]').value;
                if (hireDate && !startDate.value) {
                    startDate.value = hireDate;
                }
            } else {
                section.style.display = 'none';
                startDate.required = false;
                salary.required = false;
            }
        });

        // Auto-generate username
        const firstNameInput = document.querySelector('input[name="FirstName"]');
        const lastNameInput = document.querySelector('input[name="LastName"]');
        const usernameInput = document.getElementById('username');

        function suggestUsername() {
            if (firstNameInput.value && lastNameInput.value && !usernameInput.value) {
                const firstName = firstNameInput.value.toLowerCase().replace(/[^a-z]/g, '');
                const lastName = lastNameInput.value.toLowerCase().replace(/[^a-z]/g, '');
                usernameInput.value = firstName + '.' + lastName;
            }
        }

        firstNameInput.addEventListener('blur', suggestUsername);
        lastNameInput.addEventListener('blur', suggestUsername);
    </script>
</body>
</html>