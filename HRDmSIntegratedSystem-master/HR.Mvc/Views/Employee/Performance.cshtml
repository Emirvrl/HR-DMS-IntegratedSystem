@model HR.Mvc.Models.EmployeePerformanceViewModel
@{
    Layout = null;
    var userRole = Context.Session.GetString("UserRole");
    var isHRorAdmin = userRole == "HR" || userRole == "Admin";
    var backUrl = isHRorAdmin ? Url.Action("Index", "HR") : Url.Action("Index", "Employee");
}
<!DOCTYPE html>
<html>
<head>
    <title>Performance Reviews</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light p-4">
    <div class="container">
        <div class="d-flex justify-content-between mb-3">
            <h2><i class="fas fa-chart-line"></i> Performance Reviews</h2>
            <a href="@backUrl" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        <!-- Employee Info -->
        <div class="card mb-3">
            <div class="card-header bg-warning">
                <h4>@Model.FirstName @Model.LastName</h4>
                <small>@(Model.JobTitle ?? "No Position") | ID: @Model.EmployeeId</small>
            </div>
        </div>

        <!-- Statistics -->
        @{
            var reviews = Model.Reviews;
            var totalReviews = reviews.Count;
            var avgScore = reviews.Any() ? reviews.Average(r => r.Score ?? 0) : 0;
            var lastReview = reviews.FirstOrDefault();
        }

        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-list fa-3x text-primary mb-2"></i>
                        <h3>@totalReviews</h3>
                        <p class="text-muted">Total Reviews</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-star fa-3x text-warning mb-2"></i>
                        <h3>@avgScore.ToString("F1")</h3>
                        <p class="text-muted">Average Score</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-trophy fa-3x text-success mb-2"></i>
                        <h3>@(lastReview?.Score?.ToString() ?? "N/A")</h3>
                        <p class="text-muted">Last Score</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Performance Reviews -->
        @if (reviews.Any())
        {
            <div class="row g-3">
                @foreach (var review in reviews)
                {
                    var score = review.Score ?? 0;
                    var scoreClass = score >= 85 ? "success" : score >= 70 ? "info" : score >= 50 ? "warning" : "danger";
                    var scoreLabel = score >= 85 ? "Excellent" : score >= 70 ? "Good" : score >= 50 ? "Average" : "Needs Improvement";

                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header bg-@scoreClass text-white d-flex justify-content-between">
                                <span>@(review.ReviewDate?.ToString("dd/MM/yyyy") ?? "-")</span>
                                <span class="badge bg-light text-dark">@score / 100</span>
                            </div>
                            <div class="card-body">
                                <h5 class="text-@scoreClass">@scoreLabel</h5>
                                <div class="progress mb-3" style="height: 20px;">
                                    <div class="progress-bar bg-@scoreClass" role="progressbar" style="width: @score%">
                                        @score%
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(review.ReviewerName))
                                {
                                    <p><strong>Reviewer:</strong> @review.ReviewerName</p>
                                }
                                @if (!string.IsNullOrEmpty(review.Notes))
                                {
                                    <p><strong>Notes:</strong> @review.Notes</p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-body text-center p-5">
                    <i class="fas fa-chart-line fa-4x text-muted mb-3"></i>
                    <h4>No Performance Reviews</h4>
                    <p class="text-muted">No performance reviews found for this employee.</p>
                </div>
            </div>
        }
    </div>
</body>
</html>