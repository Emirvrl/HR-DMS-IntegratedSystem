@model List<HRDms.Data.Models.Employee>
@{
    Layout = null;
    var username = Context.Session.GetString("Username");
    var employeeName = Context.Session.GetString("EmployeeName");
    var displayName = !string.IsNullOrEmpty(employeeName) ? employeeName : username ?? "User";
}
<!DOCTYPE html>
<html>
<head>
    <title>HR Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">
    <div class="container mt-4">
        <!-- Header -->
        <div class="card mb-4 shadow">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h3><i class="fas fa-users"></i> HR Management Panel</h3>
                <div>
                    <span class="me-3">Welcome, <strong>@displayName</strong></span>
                    <a href="@Url.Action("Logout", "Login")" class="btn btn-sm btn-light">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </a>
                </div>
            </div>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <!-- Statistics -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-users fa-3x text-primary mb-2"></i>
                        <h3>@ViewBag.TotalEmployees</h3>
                        <p class="text-muted">Total Employees</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-user-check fa-3x text-success mb-2"></i>
                        <h3>@ViewBag.ActiveEmployees</h3>
                        <p class="text-muted">Active</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-building fa-3x text-info mb-2"></i>
                        <h3>@ViewBag.TotalDepartments</h3>
                        <p class="text-muted">Departments</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <i class="fas fa-user-plus fa-3x text-warning mb-2"></i>
                        <h3>@ViewBag.RecentHires</h3>
                        <p class="text-muted">New (30 Days)</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card mb-4">
            <div class="card-header bg-secondary text-white">
                <h5><i class="fas fa-bolt"></i> Quick Actions</h5>
            </div>
            <div class="card-body">
                <a href="@Url.Action("Create", "Employee")" class="btn btn-primary me-2">
                    <i class="fas fa-user-plus"></i> Add Employee
                </a>
                <a href="@Url.Action("Index", "Department")" class="btn btn-info me-2">
                    <i class="fas fa-building"></i> Departments
                </a>
                <a href="@Url.Action("Index", "LeaveRequests")" class="btn btn-warning">
                    <i class="fas fa-calendar"></i> Leave Requests
                </a>
            </div>
        </div>

        <!-- Employee List -->
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5><i class="fas fa-list"></i> Employee Directory</h5>
            </div>
            <div class="card-body">
                @if (Model != null && Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Department</th>
                                    <th>Position</th>
                                    <th>Hire Date</th>
                                    <th>Status</th>
                                    <th>HR Actions</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var employee in Model)
                                {
                                    <tr>
                                        <td>@employee.EmployeeId</td>
                                        <td>@employee.FirstName @employee.LastName</td>
                                        <td>@employee.Email</td>
                                        <td>@(employee.Department?.DepartmentName ?? "N/A")</td>
                                        <td>@(employee.Job?.JobTitle ?? "N/A")</td>
                                        <td>@(employee.HireDate?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                        <td>
                                            @if (employee.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a href="@Url.Action("Attendance", "Employee", new { id = employee.EmployeeId })"
                                                   class="btn btn-sm btn-success"
                                                   title="Attendance">
                                                    <i class="fas fa-calendar-check"></i>
                                                </a>
                                                <a href="@Url.Action("Leaves", "Employee", new { id = employee.EmployeeId })"
                                                   class="btn btn-sm btn-warning"
                                                   title="Leaves">
                                                    <i class="fas fa-umbrella-beach"></i>
                                                </a>
                                                <a href="@Url.Action("Performance", "Employee", new { id = employee.EmployeeId })"
                                                   class="btn btn-sm btn-info"
                                                   title="Performance">
                                                    <i class="fas fa-chart-line"></i>
                                                </a>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a href="@Url.Action("Details", "Employee", new { id = employee.EmployeeId })"
                                                   class="btn btn-sm btn-primary"
                                                   title="View">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="@Url.Action("Edit", "Employee", new { id = employee.EmployeeId })"
                                                   class="btn btn-sm btn-warning"
                                                   title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <button type="button"
                                                        class="btn btn-sm btn-danger"
                                                        onclick="confirmDelete(@employee.EmployeeId, '@employee.FirstName @employee.LastName')"
                                                        title="Delete">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center p-5">
                        <i class="fas fa-users-slash fa-4x text-muted mb-3"></i>
                        <h4>No Employees Found</h4>
                        <p class="text-muted">Start by adding your first employee</p>
                        <a href="@Url.Action("Create", "Employee")" class="btn btn-primary">
                            <i class="fas fa-user-plus"></i> Add First Employee
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Delete Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete <strong id="employeeName"></strong>?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form id="deleteForm" method="post" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function confirmDelete(employeeId, employeeName) {
            document.getElementById('employeeName').textContent = employeeName;
            document.getElementById('deleteForm').action = '@Url.Action("Delete", "Employee")/' + employeeId;
            const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }
    </script>
</body>
</html>